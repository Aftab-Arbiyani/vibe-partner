# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# For local dev use: STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get webhook secret by running: stripe listen --forward-to localhost:3000/api/webhook

# Firebase Admin SDK — get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gmail SMTP — use an App Password, NOT your real Gmail password
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where booking notifications are sent (can be same as GMAIL_USER)
OWNER_EMAIL=hello@vibepartner.com

# Password to access /admin dashboard
ADMIN_PASSWORD=choose-a-strong-password

# Your production domain (used in admin email links)
NEXT_PUBLIC_BASE_URL=http://localhost:9002
